(defun fibonacci (fibonacci_n)
(setq fibonacci_retorno 0)
(if (< fibonacci_n 2) 
(progn (setf fibonacci_retorno 1)) 
(progn (setf fibonacci_retorno (+ (fibonacci (- fibonacci_n 1)) (fibonacci (- fibonacci_n 2))))))
(return-from fibonacci fibonacci_retorno)
)
(defun main ()
(setq main_resultado 0)
(setq main_i 0)
(print "Sucesion de Fibonacci")
(setf main_i 2)
(loop while (< main_i 50) do
i
(setf main_i (+ main_i 1)))
)
(main)
 (main) 
